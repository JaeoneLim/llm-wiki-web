{
  "name": "llm-wiki-web",
  "description": "대화형 LLM 위키 — 웹 챗(또는 claude/antigravity CLI)으로 자료를 ingest해 함께 위키를 확장하는 도구. Quartz로 렌더링.",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "quartz": "./quartz/bootstrap-cli.mjs",
    "build": "./quartz/bootstrap-cli.mjs build -d .",
    "postbuild": "cp robots.txt public/robots.txt",
    "wiki:serve": "./quartz/bootstrap-cli.mjs build --serve -d . --wsPort 3030",
    "app": "npm --prefix app run dev",
    "dev": "node scripts/dev.mjs",
    "build:all": "npm --prefix app run build:web && npm run build",
    "serve": "npm run build:all && npm --prefix app run serve",
    "reset": "node scripts/reset.mjs",
    "check": "tsc --noEmit",
    "test": "tsx --test"
  },
  "engines": {
    "npm": ">=10.9.2",
    "node": ">=22"
  },
  "keywords": [
    "site generator",
    "ssg",
    "digital-garden",
    "markdown",
    "quartz",
    "llm",
    "wiki"
  ],
  "bin": {
    "quartz": "./quartz/bootstrap-cli.mjs"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "@floating-ui/dom": "^1.7.4",
    "@myriaddreamin/rehype-typst": "^0.6.0",
    "@napi-rs/simple-git": "0.1.22",
    "@tweenjs/tween.js": "^25.0.0",
    "ansi-truncate": "^1.4.0",
    "async-mutex": "^0.5.0",
    "chokidar": "^5.0.0",
    "cli-spinner": "^0.2.10",
    "d3": "^7.9.0",
    "esbuild-sass-plugin": "^3.6.0",
    "flexsearch": "^0.8.205",
    "github-slugger": "^2.0.0",
    "globby": "^16.1.0",
    "gray-matter": "^4.0.3",
    "hast-util-to-html": "^9.0.5",
    "hast-util-to-jsx-runtime": "^2.3.6",
    "hast-util-to-string": "^3.0.1",
    "is-absolute-url": "^5.0.0",
    "js-yaml": "^4.1.1",
    "lightningcss": "^1.31.1",
    "mdast-util-find-and-replace": "^3.0.2",
    "mdast-util-to-hast": "^13.2.1",
    "mdast-util-to-string": "^4.0.0",
    "micromorph": "^0.4.5",
    "minimatch": "^10.1.1",
    "pixi.js": "^8.15.0",
    "preact": "^10.28.2",
    "preact-render-to-string": "^6.6.5",
    "pretty-bytes": "^7.1.0",
    "pretty-time": "^1.1.0",
    "reading-time": "^1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-citation": "^2.3.1",
    "rehype-katex": "^7.0.1",
    "rehype-mathjax": "^7.1.0",
    "rehype-pretty-code": "^0.14.1",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "remark": "^15.0.1",
    "remark-breaks": "^4.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "remark-smartypants": "^3.0.2",
    "rfdc": "^1.4.1",
    "satori": "^0.19.1",
    "serve-handler": "^6.1.6",
    "sharp": "^0.34.5",
    "shiki": "^1.26.2",
    "source-map-support": "^0.5.21",
    "to-vfile": "^8.0.0",
    "toml": "^3.0.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "vfile": "^6.0.3",
    "workerpool": "^10.0.1",
    "ws": "^8.19.0",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/hast": "^3.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.0.10",
    "@types/pretty-time": "^1.1.5",
    "@types/source-map-support": "^0.5.10",
    "@types/ws": "^8.18.1",
    "@types/yargs": "^17.0.35",
    "esbuild": "^0.27.2",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
