{
  "name": "llm-wiki-web-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Chat + ingest backend and web UI for llm-wiki-web",
  "scripts": {
    "dev": "node dev.mjs",
    "dev:server": "tsx watch server/index.ts",
    "dev:web": "vite",
    "build:web": "vite build",
    "start": "NODE_ENV=production tsx server/index.ts",
    "serve": "NODE_ENV=production SERVE_WIKI=1 tsx server/index.ts",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/google": "^1.2.0",
    "@ai-sdk/openai": "^1.3.0",
    "@ai-sdk/openai-compatible": "^0.2.0",
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/static": "^8.0.0",
    "@mozilla/readability": "^0.5.0",
    "ai": "^4.3.0",
    "fastify": "^5.2.0",
    "jsdom": "^25.0.0",
    "marked": "^15.0.0",
    "pdf-parse": "^1.1.1",
    "preact": "^10.28.2",
    "turndown": "^7.2.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.0",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.10.0",
    "@types/turndown": "^5.0.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^6.0.0"
  }
}
